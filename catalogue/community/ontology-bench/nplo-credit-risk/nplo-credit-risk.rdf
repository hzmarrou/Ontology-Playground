        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/PropertyCollateral"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/externalcollection_has_quantity_returned_from_agent">
