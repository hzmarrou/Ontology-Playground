        <rdfs:comment>The indicator as to whether Contractual breach of any loans in the Counterparty Group would trigger the contractual default event of the other loans. (&quot;Full&quot;, &quot;Partial&quot;, &quot;none&quot;)</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/CounterpartyGroup"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/borrower_has_currency_of_annual_income">
