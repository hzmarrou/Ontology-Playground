<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xml:base="https://www.openriskmanual.org/ns/nplo/"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:ont="https://www.openriskmanual.org/ns/nplo/">

    <owl:Ontology rdf:about="https://www.openriskmanual.org/ns/nplo/">
        <rdfs:label>NPLO Credit Risk</rdfs:label>
        <rdfs:comment>Non-Performing Loan Ontology (NPLO) v0.1 aligned with European Banking Authority NPL Data Templates. Full ontology: 18 OWL classes with hierarchy, 16 object properties, 338 datatype properties with EBA field references. Plus 5 FK-based relationships and LoanBorrowerLink junction entity for Fabric integration.</rdfs:comment>
    </owl:Ontology>

    <!-- ===================== -->
    <!-- Entity Types (Classes) -->
    <!-- ===================== -->

    <owl:Class rdf:about="https://www.openriskmanual.org/ns/nplo/Borrower">
        <rdfs:label>Borrower</rdfs:label>
        <rdfs:comment>Borrower Class. A sub-class of Counterparty that applies to Lending relations</rdfs:comment>
        <ont:icon>👤</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="https://www.openriskmanual.org/ns/nplo/Collateral">
        <rdfs:label>Collateral</rdfs:label>
        <rdfs:comment>General Collateral Class</rdfs:comment>
        <ont:icon>💎</ont:icon>
        <ont:color>#FFB900</ont:color>
    </owl:Class>

    <owl:Class rdf:about="https://www.openriskmanual.org/ns/nplo/CollectionAgent">
        <rdfs:label>CollectionAgent</rdfs:label>
        <rdfs:comment>Collection Agent class</rdfs:comment>
        <ont:icon>🕵</ont:icon>
        <ont:color>#4A154B</ont:color>
    </owl:Class>

    <owl:Class rdf:about="https://www.openriskmanual.org/ns/nplo/CounterpartyGroup">
        <rdfs:label>CounterpartyGroup</rdfs:label>
        <rdfs:comment>Counterparty Group Class</rdfs:comment>
        <ont:icon>🏢</ont:icon>
        <ont:color>#107C10</ont:color>
    </owl:Class>

    <owl:Class rdf:about="https://www.openriskmanual.org/ns/nplo/Enforcement">
        <rdfs:label>Enforcement</rdfs:label>
        <rdfs:comment>Enforcement Class</rdfs:comment>
        <ont:icon>⚖</ont:icon>
        <ont:color>#8764B8</ont:color>
    </owl:Class>

    <owl:Class rdf:about="https://www.openriskmanual.org/ns/nplo/ExternalCollection">
        <rdfs:label>ExternalCollection</rdfs:label>
        <rdfs:comment>External Collection Class</rdfs:comment>
        <ont:icon>📞</ont:icon>
        <ont:color>#E3008C</ont:color>
    </owl:Class>

    <owl:Class rdf:about="https://www.openriskmanual.org/ns/nplo/Forbearance">
        <rdfs:label>Forbearance</rdfs:label>
        <rdfs:comment>Forbearance Class</rdfs:comment>
        <ont:icon>🤝</ont:icon>
        <ont:color>#008272</ont:color>
    </owl:Class>

    <owl:Class rdf:about="https://www.openriskmanual.org/ns/nplo/InsolvencyPractitioner">
        <rdfs:label>InsolvencyPractitioner</rdfs:label>
        <rdfs:comment>Insolvency Practitioner Class</rdfs:comment>
        <ont:icon>📋</ont:icon>
        <ont:color>#7A7574</ont:color>
    </owl:Class>

    <owl:Class rdf:about="https://www.openriskmanual.org/ns/nplo/InsuranceProvider">
        <rdfs:label>InsuranceProvider</rdfs:label>
        <rdfs:comment>Insurance Provider Class</rdfs:comment>
        <ont:icon>🛡</ont:icon>
        <ont:color>#0063B1</ont:color>
    </owl:Class>

    <owl:Class rdf:about="https://www.openriskmanual.org/ns/nplo/Loan">
        <rdfs:label>Loan</rdfs:label>
        <rdfs:comment>Loan class</rdfs:comment>
        <ont:icon>📄</ont:icon>
        <ont:color>#D13438</ont:color>
    </owl:Class>

    <owl:Class rdf:about="https://www.openriskmanual.org/ns/nplo/PropertyCollateral">
        <rdfs:label>PropertyCollateral</rdfs:label>
        <rdfs:comment>Property Collateral Class</rdfs:comment>
        <ont:icon>🏗</ont:icon>
        <ont:color>#CA5010</ont:color>
    </owl:Class>

    <owl:Class rdf:about="https://www.openriskmanual.org/ns/nplo/RatingAgency">
        <rdfs:label>RatingAgency</rdfs:label>
        <rdfs:comment>Credit Rating Agency Class</rdfs:comment>
        <ont:icon>⭐</ont:icon>
        <ont:color>#C19C00</ont:color>
    </owl:Class>

    <owl:Class rdf:about="https://www.openriskmanual.org/ns/nplo/Receiver">
        <rdfs:label>Receiver</rdfs:label>
        <rdfs:comment>Receiver Class</rdfs:comment>
        <ont:icon>🔨</ont:icon>
        <ont:color>#486860</ont:color>
    </owl:Class>

    <!-- ================ -->
    <!-- Data Properties   -->
    <!-- ================ -->

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/loan_has_accounting_stages_of_asset_quality">
        <rdfs:label>has_accounting_stages_of_asset_quality</rdfs:label>
        <rdfs:comment>Accounting stages of asset quality, i.e. IFRS Stage 1, IFRS Stage 2, IFRS Stage 3 (impaired), Fair Value Through P&amp;L, Other Accounting Standard – impaired asset, Other Accounting Standard – Not impaired</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Loan"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/loan_has_accrued_interest_balance_off_book">
        <rdfs:label>has_accrued_interest_balance_off_book</rdfs:label>
        <rdfs:comment>Amount of interest that has been accrued but not capitalized to the Loan, as not recognized on the balance sheet</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Loan"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/loan_has_accrued_interest_balance_on_book">
        <rdfs:label>has_accrued_interest_balance_on_book</rdfs:label>
        <rdfs:comment>Current amount of outstanding interest as recognised on the balance sheet at the NPL Portfolio Cut-Off Date</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Loan"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/collateral_has_activation_of_guarantee">
        <rdfs:label>has_activation_of_guarantee</rdfs:label>
        <rdfs:comment>Indicator as to whether the guarantee has been activated when &quot;Guarantee&quot; is selected in field &quot;Collateral Type&quot;</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Collateral"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <ont:propertyType>boolean</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/borrower_has_additional_name_of_insolvencyorrestructuring_proceedings">
        <rdfs:label>has_additional_name_of_insolvencyorrestructuring_proceedings</rdfs:label>
        <rdfs:comment>Additional name of any insolvency or restructuring proceedings to which the Counterparty is subject</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Borrower"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/borrower_has_additional_stage_reached_in_insolvencyorrestructuring_procedure">
        <rdfs:label>has_additional_stage_reached_in_insolvencyorrestructuring_procedure</rdfs:label>
        <rdfs:comment>Additional indication of how advanced the relevant procedure has become as a result of various legal steps in the legal procedure having been completeted</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Borrower"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/propertycollateral_has_address_of_property">
        <rdfs:label>has_address_of_property</rdfs:label>
        <rdfs:comment>Street address where the Property is located at, including flat / house number or name</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/PropertyCollateral"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/borrower_has_address_of_registered_location">
        <rdfs:label>has_address_of_registered_location</rdfs:label>
        <rdfs:comment>Address where the Corporate Counterparty is registered, including flat / house number</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Borrower"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/borrower_has_address_of_residence">
        <rdfs:label>has_address_of_residence</rdfs:label>
        <rdfs:comment>Street address where the Private Individual Counterparty lives, including flat / house number</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Borrower"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/loan_has_amortisation_type">
        <rdfs:label>has_amortisation_type</rdfs:label>
        <rdfs:comment>Description of the Amortisation type of the loan as per the latest Loan Agreement</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Loan"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/enforcement_has_amount_of_outstanding_liabilities">
        <rdfs:label>has_amount_of_outstanding_liabilities</rdfs:label>
        <rdfs:comment>Amount of accrued costs and fees paid by the receiver and to be invoiced to the Institution</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Enforcement"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/forbearance_has_amount_of_repayment_step_up">
        <rdfs:label>has_amount_of_repayment_step_up</rdfs:label>
        <rdfs:comment>Additional amount that the current agreed forbearance amount is increased by</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Forbearance"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/propertycollateral_has_amount_of_vat_payable">
        <rdfs:label>has_amount_of_vat_payable</rdfs:label>
        <rdfs:comment>Amount of VAT payable on the disposal of the Unit</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/PropertyCollateral"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/borrower_has_annual_ebit">
        <rdfs:label>has_annual_ebit</rdfs:label>
        <rdfs:comment>Amount of annual EBIT held by the Corporate Counterparty as per the latest available financial statements</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Borrower"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/borrower_has_annual_income">
        <rdfs:label>has_annual_income</rdfs:label>
        <rdfs:comment>Total annual income of the Private Individual Counterparty</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Borrower"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/enforcement_has_annual_insurance_payment">
        <rdfs:label>has_annual_insurance_payment</rdfs:label>
        <rdfs:comment>Annual insurance payment to be paid by receiver</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Enforcement"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/borrower_has_annual_revenue">
        <rdfs:label>has_annual_revenue</rdfs:label>
        <rdfs:comment>Amount of annual revenue held by the Corporate Counterparty as per the latest available financial statements</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Borrower"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/propertycollateral_has_area_type_of_property">
        <rdfs:label>has_area_type_of_property</rdfs:label>
        <rdfs:comment>Area type where the Property is located at , i.e. City centre, Suburban and Rural</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/PropertyCollateral"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/collateral_has_asset_purchase_obligation">
        <rdfs:label>has_asset_purchase_obligation</rdfs:label>
        <rdfs:comment>Indicator as to whether there is an obligation for the Borrower to purchase the Collateral at the end of the lease</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Collateral"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <ont:propertyType>boolean</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/externalcollection_has_balance_amount_sent_to_agent">
        <rdfs:label>has_balance_amount_sent_to_agent</rdfs:label>
        <rdfs:comment>The Balance that was sent to the External Debt Collection Agent</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/ExternalCollection"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/loan_has_balance_at_default">
        <rdfs:label>has_balance_at_default</rdfs:label>
        <rdfs:comment>Balance of the Loan when the Loan has defaulted (CRR Art.178)</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Loan"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/borrower_has_basis_of_financial_statements">
        <rdfs:label>has_basis_of_financial_statements</rdfs:label>
        <rdfs:comment>Financial reporting practice the Corporate Counterparty has adopted</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Borrower"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/propertycollateral_has_building_area_m2">
        <rdfs:label>has_building_area_m2</rdfs:label>
        <rdfs:comment>Building area (square metres) of the Unit</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/PropertyCollateral"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/propertycollateral_has_building_area_m2_lettable">
        <rdfs:label>has_building_area_m2_lettable</rdfs:label>
        <rdfs:comment>Building area (square metres) of the Unit that is lettable</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/PropertyCollateral"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/propertycollateral_has_building_area_m2_occupied">
        <rdfs:label>has_building_area_m2_occupied</rdfs:label>
        <rdfs:comment>Building area (square metres) of the Unit that has been occupied by landlord / tenant</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/PropertyCollateral"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/borrower_has_business_description">
        <rdfs:label>has_business_description</rdfs:label>
        <rdfs:comment>Description of the business operations of the Corporate Counterparty, providing more detail for field &quot;Industry Segment&quot;</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Borrower"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/loan_has_capitalised_pastdue_amount">
        <rdfs:label>has_capitalised_pastdue_amount</rdfs:label>
        <rdfs:comment>Total capitalised past-due balance as recognised on balance sheet at NPL Portfolio Cut-Off Date i.e. Interest and Legal Fees</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Loan"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/borrower_has_cash_and_cash_equivalent_items">
        <rdfs:label>has_cash_and_cash_equivalent_items</rdfs:label>
        <rdfs:comment>Amount of cash and cash equivalent items held by the Corporate Counterparty as per the latest available financial statements</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Borrower"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/externalcollection_has_cash_recoveries">
        <rdfs:label>has_cash_recoveries</rdfs:label>
        <rdfs:comment>Total cash recoveries collected by the external collection agent</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/ExternalCollection"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/loan_has_channel_of_origination">
        <rdfs:label>has_channel_of_origination</rdfs:label>
        <rdfs:comment>Channel through which the Loan was originated, i.e. Branch, Internet and Broker</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Loan"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/loan_has_chargeoff_date">
        <rdfs:label>has_chargeoff_date</rdfs:label>
        <rdfs:comment>Date when the Loan went into charge-off. A charge-off is the declaration by the Institution commonly on Unsecured Retail when the Borrower is severely delinquent, and the Institution starts the recovery process officially.</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Loan"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <ont:propertyType>datetime</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/propertycollateral_has_city_of_property">
        <rdfs:label>has_city_of_property</rdfs:label>
        <rdfs:comment>City where the Property is located at</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/PropertyCollateral"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/borrower_has_city_of_registered_location">
        <rdfs:label>has_city_of_registered_location</rdfs:label>
        <rdfs:comment>City where the Corporate Counterparty is registered</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Borrower"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/borrower_has_city_of_residence">
        <rdfs:label>has_city_of_residence</rdfs:label>
