    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/enforcement_has_other_ongoing_enforcement_proceedings">
        <rdfs:label>has_other_ongoing_enforcement_proceedings</rdfs:label>
