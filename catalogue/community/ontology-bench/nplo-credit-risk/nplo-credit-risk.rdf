        <ont:propertyType>datetime</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/enforcement_has_on_market_price">
        <rdfs:label>has_on_market_price</rdfs:label>
