        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Collateral"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <ont:propertyType>datetime</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/borrower_has_date_of_internal_demand_issuance">
        <rdfs:label>has_date_of_internal_demand_issuance</rdfs:label>
