        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Borrower"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <ont:propertyType>datetime</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/loan_has_days_in_pastdue">
        <rdfs:label>has_days_in_pastdue</rdfs:label>
        <rdfs:comment>Number of days that the Loan is currently past-due as at the NPL Portfolio Cut-Off Date</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Loan"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/loan_has_default_penalty_interest_margin">
        <rdfs:label>has_default_penalty_interest_margin</rdfs:label>
