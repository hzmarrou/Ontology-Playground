        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/loan_has_description_of_bespoke_repayment">
        <rdfs:label>has_description_of_bespoke_repayment</rdfs:label>
        <rdfs:comment>Description of the bespoke repayment profile when &quot;Bespoke Repayment&quot; is selected in field &quot;Amortisation Type&quot;</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Loan"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/borrower_has_description_of_contingent_obligations">
