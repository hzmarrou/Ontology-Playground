        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/collateral_has_current_opex_and_overheads">
        <rdfs:label>has_current_opex_and_overheads</rdfs:label>
        <rdfs:comment>Current annual operational expenses and overheads of running the Collateral as at cut-off date</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Collateral"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/loan_has_current_reversion_interest_rate">
        <rdfs:label>has_current_reversion_interest_rate</rdfs:label>
        <rdfs:comment>Current level of reversion interest rate according to the Loan Agreement and applicable as at NPL Portfolio Cut-Off Date, reversion means that after the interest fixed period the Institution would revert the rate to a different type, e.g. the Institution's Standard Variable Rate</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Loan"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/enforcement_has_date_next_insurance_payment_is_due">
        <rdfs:label>has_date_next_insurance_payment_is_due</rdfs:label>
        <rdfs:comment>Date that the next insurance payment is due</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Enforcement"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <ont:propertyType>datetime</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/borrower_has_date_of_appointment">
