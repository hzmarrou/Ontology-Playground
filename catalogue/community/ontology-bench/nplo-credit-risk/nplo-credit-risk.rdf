    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/borrower_has_cross_default_for_counterparty">
        <rdfs:label>has_cross_default_for_counterparty</rdfs:label>
        <rdfs:comment>Indicator as to whether contractual breach of any loans held by the Counterparty would trigger the default event of any other loans</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Borrower"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
