        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Loan"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <ont:propertyType>datetime</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/forbearance_has_date_of_principal_forgiveness">
        <rdfs:label>has_date_of_principal_forgiveness</rdfs:label>
