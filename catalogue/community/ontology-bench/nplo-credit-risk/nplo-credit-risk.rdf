        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Forbearance"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <ont:propertyType>datetime</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/collateral_has_date_of_the_latest_residual_valuation">
        <rdfs:label>has_date_of_the_latest_residual_valuation</rdfs:label>
        <rdfs:comment>Date that the latest residual value of the Collateral was assessed, residual value refers to how much the Collateral will be worth at end of the loan term</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Collateral"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <ont:propertyType>datetime</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/borrower_has_date_of_verification_for_personal_details">
        <rdfs:label>has_date_of_verification_for_personal_details</rdfs:label>
        <rdfs:comment>Date that the personal details of the Private Individual Counterparty, i.e. nationality, residence, annual income and occupation in the above fields, were last verified</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Borrower"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <ont:propertyType>datetime</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/externalcollection_has_date_returned_from_agent">
        <rdfs:label>has_date_returned_from_agent</rdfs:label>
        <rdfs:comment>Date that the Loan was received back from the external collection agent, i.e. when the agent stopped recovery efforts and passed the Loan back to the Institution</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/ExternalCollection"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <ont:propertyType>datetime</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/externalcollection_has_date_sent_to_agent">
        <rdfs:label>has_date_sent_to_agent</rdfs:label>
        <rdfs:comment>Date that the Loan was sent to the external collection agent</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/ExternalCollection"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <ont:propertyType>datetime</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/borrower_has_date_when_reservation_of_rights_letter_was_issued">
        <rdfs:label>has_date_when_reservation_of_rights_letter_was_issued</rdfs:label>
