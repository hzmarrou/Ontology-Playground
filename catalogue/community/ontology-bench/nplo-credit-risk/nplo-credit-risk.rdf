        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Loan"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <ont:propertyType>datetime</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/borrower_has_date_of_external_demand_issuance">
        <rdfs:label>has_date_of_external_demand_issuance</rdfs:label>
