        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Enforcement"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <ont:propertyType>datetime</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/forbearance_has_date_of_repayment_step_up">
        <rdfs:label>has_date_of_repayment_step_up</rdfs:label>
