    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/loan_has_original_interest_base_rate">
        <rdfs:label>has_original_interest_base_rate</rdfs:label>
        <rdfs:comment>Original base rate of the Loan when &quot;Variable&quot; is selected in field &quot;Original Interest Rate Type&quot;</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Loan"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/loan_has_original_interest_margin">
        <rdfs:label>has_original_interest_margin</rdfs:label>
