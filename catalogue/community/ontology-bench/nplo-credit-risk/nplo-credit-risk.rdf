    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/forbearance_has_repayment_amount_under_forbearance">
        <rdfs:label>has_repayment_amount_under_forbearance</rdfs:label>
        <rdfs:comment>Periodic repayment amount that the Institution and Counterparty agreed under the current forbearance terms</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Forbearance"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/forbearance_has_repayment_frequency_under_forbearance">
        <rdfs:label>has_repayment_frequency_under_forbearance</rdfs:label>
        <rdfs:comment>Frequency that the repayment under current forbearance terms is made</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Forbearance"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/externalcollection_has_repayment_plan">
        <rdfs:label>has_repayment_plan</rdfs:label>
        <rdfs:comment>Indicator as to whether a repayment plan has been agreed with the external collection agency</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/ExternalCollection"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <ont:propertyType>boolean</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/externalcollection_has_repayment_plan_description">
        <rdfs:label>has_repayment_plan_description</rdfs:label>
        <rdfs:comment>Description of the repayment plan which has been agreed with the external collection agency</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/ExternalCollection"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/enforcement_has_sale_agreed_date">
        <rdfs:label>has_sale_agreed_date</rdfs:label>
        <rdfs:comment>Sale agreed date</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Enforcement"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <ont:propertyType>datetime</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/enforcement_has_sale_agreed_price">
        <rdfs:label>has_sale_agreed_price</rdfs:label>
        <rdfs:comment>Agreed price for the disposal of the Property / Collateral</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Enforcement"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/propertycollateral_has_sector_of_property">
        <rdfs:label>has_sector_of_property</rdfs:label>
        <rdfs:comment>Sector which the property is used for, e.g. commercial real estate, residential real estate, etc.</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/PropertyCollateral"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/loan_has_securitised">
        <rdfs:label>has_securitised</rdfs:label>
        <rdfs:comment>Indicator as to whether the Loan has been securitised or within covered bond pool</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Loan"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <ont:propertyType>boolean</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/borrower_has_sheriff_or_bailiff_acquisition_date">
        <rdfs:label>has_sheriff_or_bailiff_acquisition_date</rdfs:label>
        <rdfs:comment>Date that sheriff / bailiff is acquired by the court</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Borrower"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <ont:propertyType>datetime</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/enforcement_has_sold_date">
        <rdfs:label>has_sold_date</rdfs:label>
        <rdfs:comment>Sold date</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Enforcement"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <ont:propertyType>datetime</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/loan_has_specialised_product">
        <rdfs:label>has_specialised_product</rdfs:label>
        <rdfs:comment>Indicator as to whether the Loan is a specialised product, e.g. Fractioned Loans in Italy</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Loan"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <ont:propertyType>boolean</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/borrower_has_stage_reached_in_insolvencyorrestructuring_procedure">
        <rdfs:label>has_stage_reached_in_insolvencyorrestructuring_procedure</rdfs:label>
        <rdfs:comment>Stage Reached in Insolvency/Restructuring procedure</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Borrower"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/loan_has_start_date_of_current_fixed_interest_period">
        <rdfs:label>has_start_date_of_current_fixed_interest_period</rdfs:label>
        <rdfs:comment>Date that the current fixed interest period started according to the Loan Agreement and applicable as at the NPL Portfolio Cut-Off Date</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Loan"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <ont:propertyType>datetime</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/forbearance_has_start_date_of_forbearance">
        <rdfs:label>has_start_date_of_forbearance</rdfs:label>
        <rdfs:comment>Date that the current forbearance arrangement starts</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Forbearance"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <ont:propertyType>datetime</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/loan_has_start_date_of_interest_grace_period">
        <rdfs:label>has_start_date_of_interest_grace_period</rdfs:label>
        <rdfs:comment>Date that the interest payment starts being postponed according to the Loan Agreement and applicable as of the NPL Portfolio Cut-Off Date</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Loan"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <ont:propertyType>datetime</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/loan_has_start_date_of_interest_only_period">
        <rdfs:label>has_start_date_of_interest_only_period</rdfs:label>
        <rdfs:comment>Date that the interest repayment only period starts according to the most recent Loan Agreement and applicable as  the NPL Portfolio Cut-Off Date</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Loan"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <ont:propertyType>datetime</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/loan_has_start_date_of_principal_grace_period">
        <rdfs:label>has_start_date_of_principal_grace_period</rdfs:label>
        <rdfs:comment>Date that the principal payment starts being postponed according to the Loan Agreement and applicable as of the NPL Portfolio Cut-Off Date</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Loan"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <ont:propertyType>datetime</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/loan_has_start_date_of_subsidy">
        <rdfs:label>has_start_date_of_subsidy</rdfs:label>
        <rdfs:comment>Date that the current subsidy starts</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Loan"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <ont:propertyType>datetime</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/loan_has_subsidy">
        <rdfs:label>has_subsidy</rdfs:label>
        <rdfs:comment>Indicator where contractual payments are subsidised by an external party</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Loan"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <ont:propertyType>boolean</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/loan_has_subsidy_amount">
        <rdfs:label>has_subsidy_amount</rdfs:label>
        <rdfs:comment>Amount of the subsidy received</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Loan"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/loan_has_subsidy_provider">
        <rdfs:label>has_subsidy_provider</rdfs:label>
        <rdfs:comment>Name of the external party who provided the subsidy</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Loan"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/loan_has_syndicated_loan">
        <rdfs:label>has_syndicated_loan</rdfs:label>
        <rdfs:comment>Indicator as to whether the Loan is provided by a syndicate or consortium of two or more institutions. This means that in the case of a syndicated loan the Institution holds less than 100% of the total loan</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Loan"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <ont:propertyType>boolean</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/loan_has_syndicated_portion">
        <rdfs:label>has_syndicated_portion</rdfs:label>
        <rdfs:comment>Percentage of the portion held by the Institution when &quot;Yes&quot; is selected in field &quot;Syndicated Loan&quot;</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Loan"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/propertycollateral_has_tenure">
        <rdfs:label>has_tenure</rdfs:label>
        <rdfs:comment>Conditions that the Property is held or occupied, e.g. freehold and leasehold</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/PropertyCollateral"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/loan_has_time_in_pastdue">
        <rdfs:label>has_time_in_pastdue</rdfs:label>
        <rdfs:comment>Total number of months that the Loan has been in past-due in the past 12 months</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Loan"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/borrower_has_total_assets">
        <rdfs:label>has_total_assets</rdfs:label>
        <rdfs:comment>Amount of total assets held by the Corporate Counterparty as per the latest available financial statements</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Borrower"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/loan_has_total_balance">
        <rdfs:label>has_total_balance</rdfs:label>
        <rdfs:comment>Total unpaid balance, i.e. Principal Balance + Accrued Interest Balance (On book) + Other Balances</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Loan"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/borrower_has_total_debt">
        <rdfs:label>has_total_debt</rdfs:label>
        <rdfs:comment>Amount of total debt held by the Corporate Counterparty as per the latest available financial statements</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Borrower"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/borrower_has_total_liabilities">
        <rdfs:label>has_total_liabilities</rdfs:label>
        <rdfs:comment>Amount of total liabilities held by the Corporate Counterparty on the balance sheet as defined by the applicable accounting standard as per the latest available financial statements</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Borrower"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/loan_has_total_pastdue_amount">
        <rdfs:label>has_total_pastdue_amount</rdfs:label>
        <rdfs:comment>Total past-due amount, i.e. Past-Due Principal Amount + Past-Due Interest Amount + Other Past-Due Amount</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Loan"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/loan_has_trigger_levels_of_loan_covenants">
        <rdfs:label>has_trigger_levels_of_loan_covenants</rdfs:label>
        <rdfs:comment>Corresponding trigger levels as agreed in the Loan Agreement, as at the NPL Portfolio Cut-Off Date, each in a separate column</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Loan"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/forbearance_has_type_of_forbearance">
        <rdfs:label>has_type_of_forbearance</rdfs:label>
        <rdfs:comment>Type of current forbearance</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Forbearance"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/externalcollection_has_type_of_identifier">
        <rdfs:label>has_type_of_identifier</rdfs:label>
        <rdfs:comment>Indicator as to whether the external collections have been prepared on a Counterparty level or on a Loan Level</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/ExternalCollection"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/collateral_has_type_of_initial_valuation">
        <rdfs:label>has_type_of_initial_valuation</rdfs:label>
        <rdfs:comment>Type of the initial valuation</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Collateral"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/collateral_has_type_of_latest_valuation">
        <rdfs:label>has_type_of_latest_valuation</rdfs:label>
        <rdfs:comment>Type of the latest valuation for the Collateral</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Collateral"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/collateral_has_type_of_legal_owner">
        <rdfs:label>has_type_of_legal_owner</rdfs:label>
        <rdfs:comment>Type of the legal owner, i.e. Private Individual, Listed Corporate, Unlisted Corporate and Partnership</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Collateral"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/propertycollateral_has_type_of_occupancy">
        <rdfs:label>has_type_of_occupancy</rdfs:label>
        <rdfs:comment>Type of occupancy, i.e. owner occupied, tenanted, not tenanted</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/PropertyCollateral"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/borrower_has_type_of_personal_identity_number">
        <rdfs:label>has_type_of_personal_identity_number</rdfs:label>
        <rdfs:comment>Type of the personal identity number entered in field &quot;Personal Identity Number&quot;, e.g. National Insurance Number, Passport Number, National Tax Number</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Borrower"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/propertycollateral_has_type_of_property">
        <rdfs:label>has_type_of_property</rdfs:label>
        <rdfs:comment>Type of the Property, e.g. Apartment, Semi Detached House, Terraced House, Land, etc.</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/PropertyCollateral"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/loan_has_type_of_reversion_interest_rate">
        <rdfs:label>has_type_of_reversion_interest_rate</rdfs:label>
        <rdfs:comment>Type of reversion interest rate after the fixed interest period according to the Loan Agreement and applicable as of the NPL Portfolio Cur-Off Date, reversion means that after the interest fixed period the Institution would revert the rate to a different type, e.g. the Institution's Standard Variable Rate</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/Loan"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/counterpartygroup_has_type_of_sponsor">
        <rdfs:label>has_type_of_sponsor</rdfs:label>
        <rdfs:comment>Type of entity the sponsor is i.e. Listed Corporate, Unlisted Corporate, Listed Fund, Unlisted Fund and High Net Worth Individual</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/CounterpartyGroup"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/propertycollateral_has_value_of_energy_performance_certificate">
        <rdfs:label>has_value_of_energy_performance_certificate</rdfs:label>
        <rdfs:comment>Value stated on Energy Performance Certificate</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/PropertyCollateral"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://www.openriskmanual.org/ns/nplo/propertycollateral_has_vat_payable">
        <rdfs:label>has_vat_payable</rdfs:label>
        <rdfs:comment>Indicator as to whether the VAT is payable on the disposal of the Unit</rdfs:comment>
        <rdfs:domain rdf:resource="https://www.openriskmanual.org/ns/nplo/PropertyCollateral"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <ont:propertyType>boolean</ont:propertyType>
